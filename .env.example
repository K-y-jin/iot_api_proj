# .env 예시. 실제 .env 파일은 git에 커밋하지 않는다 (DESIGN.md §14).
# 사용 시 이 파일을 복사하여 .env로 저장 후 값을 채워 사용.

# Aqara Open API 인증 정보 (https://developer.aqara.com/ Console > Manage Project > Detail)
AQARA_APPID=
AQARA_KEYID=
AQARA_APPKEY=
AQARA_API_URL=https://open-kr.aqara.com/v3.0/open/api

# 최초 관리자 계정 비밀번호 (앱 첫 기동 시 admin 계정 자동 생성에 사용)
ADMIN_INITIAL_PASSWORD=changeme

# 세션 쿠키 서명용 시크릿 (충분히 긴 임의의 문자열)
SESSION_SECRET=please-change-this-to-a-long-random-string

# 데이터/DB/토큰 파일 경로 (선택, 미설정 시 프로젝트 루트 기준 상대경로 기본값 사용)
# DATA_DIR=./data
# DB_PATH=./app.db
# TOKENS_PATH=./tokens.json
# SMARTTHINGS_TOKEN_PATH=./tokens_smartthings.json

# ─────────────── SmartThings OAuth 2.0 (DESIGN.md §15.2) ───────────────
# SmartThings Developer Workspace 에서 OAuth-In 클라이언트 생성 후 발급받은 값.
# redirect_uri 는 클라이언트에 등록한 콜백 주소와 정확히 일치해야 한다.
SMARTTHINGS_CLIENT_ID=
SMARTTHINGS_CLIENT_SECRET=
SMARTTHINGS_OAUTH_REDIRECT_URI=http://localhost:8000/admin/smartthings/oauth/callback
# 공백 구분 scope (디바이스·장소 조회 + history). 필요 시 조정.
SMARTTHINGS_OAUTH_SCOPE=r:devices:* r:locations:* x:devices:*
# OAuth 엔드포인트 (보통 기본값 그대로 사용)
# SMARTTHINGS_OAUTH_AUTHORIZE_URL=https://api.smartthings.com/oauth/authorize
# SMARTTHINGS_OAUTH_TOKEN_URL=https://auth-global.api.smartthings.com/oauth/token
# SmartThings CLI 실행 파일 절대 경로 (선택, 미설정 시 PATH 에서 'smartthings' 자동 탐색)
# SMARTTHINGS_CLI_PATH=C:\Program Files\SmartThings\smartthings.exe

# [임시 stopgap] OAuth 클라이언트가 아직 준비되지 않았을 때 PAT 로 즉시 운영하는 모드.
# 이 값이 설정돼 있으면 OAuth 를 *완전히 우회* 하고 PAT 를 Bearer 토큰으로 그대로 사용.
# refresh 없음 — 만료/거부 시 새 PAT 를 발급해 이 변수를 갱신해야 함.
# OAuth 가 준비되면 이 라인을 비우고 재시작 → 정식 OAuth 경로로 복귀.
# SMARTTHINGS_PAT=
